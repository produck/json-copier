{
  "devDependencies": {
    "@eslint/compat": "^2.0.3",
    "@eslint/config-helpers": "0.6.0",
    "@eslint/js": "10.0.1",
    "@eslint/json": "2.0.0",
    "@eslint/markdown": "8.0.2",
    "@produck/agent-toolkit": "0.11.1",
    "@produck/eslint-rules": "0.4.1",
    "@types/node": "^25.5.0",
    "c8": "11.0.0",
    "eslint": "10.6.0",
    "globals": "17.7.0",
    "husky": "9.1.7",
    "lerna": "9.0.7",
    "prettier": "3.9.1",
    "typescript-eslint": "8.62.0"
  },
  "license": "MIT",
  "name": "@produck/json-copier-workspace",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "produck:baseline": "npm exec --package=@produck/agent-toolkit@latest -- agent-toolkit enforce-node-baseline --cwd . && npm run produck:install",
    "produck:commit:check": "npm run produck:format && npm run produck:lint",
    "produck:coverage": "c8 --config .c8rc.json npm run test --workspaces --if-present",
    "produck:format": "prettier --write . --ignore-path .prettierignore --ignore-path .gitignore",
    "produck:install": "npm -v && npm install",
    "produck:lint": "eslint --fix . --max-warnings=0",
    "produck:publish": "npm run produck:publish:check && npm run publish --",
    "produck:publish:check": "npm run produck:install && npm run produck:coverage && npm run produck:commit:check",
    "publish": "lerna publish",
    "test": "npm run test --workspaces --if-present"
  },
  "workspaces": [
    "packages/json-copier"
  ]
}
